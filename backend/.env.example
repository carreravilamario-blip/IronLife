# ============================================================
#  .env.example — Plantilla de variables de entorno.
#
#  INSTRUCCIONES:
#  1. Copia este archivo como ".env"  →  cp .env.example .env
#  2. Rellena los valores reales (los que tienen CAMBIAR_POR_...)
#  3. NUNCA subas el ".env" real a git (está en .gitignore)
#
#  Este archivo .env.example SÍ se sube a git: no contiene
#  secretos, solo sirve de guía para nuevos desarrolladores.
# ============================================================

# ── Base de datos PostgreSQL ───────────────────────────────────
# Formato: postgresql+psycopg://USUARIO:CONTRASEÑA@SERVIDOR:PUERTO/BD
DATABASE_URL=postgresql+psycopg://postgres:CAMBIAR_POR_TU_PASSWORD@localhost:5432/gymapp

# ── Seguridad JWT ──────────────────────────────────────────────
# Clave secreta larga y aleatoria. Generarla con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_DE_64_CARACTERES_HEX

# Algoritmo de firma (HS256 es el estándar para JWT simétrico)
ALGORITHM=HS256

# Tiempo de vida de los tokens (en minutos). 1440 = 24 horas.
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ───────────────────────────────────────────────────────
# Orígenes del front-end separados por coma.
# En desarrollo: el servidor de Vite. En producción: tu dominio real.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Entorno ────────────────────────────────────────────────────
# "development" → muestra /docs y /redoc
# "production"  → oculta los docs de la API
APP_ENV=development
