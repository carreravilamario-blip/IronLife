{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "IronLife: Arrancar todo",
      "dependsOn": ["IronLife: Backend", "IronLife: Frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "IronLife: Backend",
      "type": "shell",
      "command": "uv run uvicorn app.main:app --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "ironlife"
      },
      "problemMatcher": []
    },
    {
      "label": "IronLife: Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "group": "ironlife"
      },
      "problemMatcher": []
    }
  ]
}
